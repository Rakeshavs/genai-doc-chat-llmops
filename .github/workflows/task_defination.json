{
  "family": "llmopstdlive",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::363401891398:role/ecsTaskExecutionRole",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "8192",
  "containerDefinitions": [
    {
      "name": "llmops-live-container",
      "image": "363401891398.dkr.ecr.ap-southeast-2.amazonaws.com/llmopsrepolive",
      "cpu": 1024,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "llmops-live-container-8080-tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "apikeyliveclass",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:363401891398:secret:apikeyliveclass-9KfU0N"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/llmopstdlive",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}